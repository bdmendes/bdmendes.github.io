---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="404: Not Found" currentPage={1}>
  <div class="text-center">
    <h1 class="text-8xl font-bold mb-9 mt-6">🥦</h1>
    <h1 class="text-4xl font-bold mb-3">There's nothing here</h1>
    <h3 class="text-lg">
      If you came from a search engine, it is likely I moved this content to a
      different location. Please look around.
    </h3>
  </div>
</BaseLayout>
