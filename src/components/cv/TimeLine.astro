---
export interface Props {
  title: string;
  from: string;
  to?: string;
  location: string;
  grade?: string;
}

const { title, from, to, location, grade } = Astro.props;
---

<div class="flex mb-4">
  <div class="entry_time pr-5">
    <span class="w-4 h-4 bg-neutral block rounded-full mt-1"></span>
    <span class="entry_line bg-neutral block h-full w-0.5 translate-x-1.75"
    ></span>
  </div>
  <div class="entry_data bd-grid">
    <div class="font-semibold mb-1 flex items-baseline flex-wrap gap-2">
      <span>{title} @ {location}</span>
      <span class="badge badge-dash font-normal text-sm"
        >{from} {to ? (to != from ? `- ${to}` : "") : "- Present"}</span
      >
      {
        grade && (
          <span class="badge badge-dash font-normal text-sm">{grade}</span>
        )
      }
    </div>
    <p class="my-2 text-justify">
      <slot />
    </p>
  </div>
</div>
